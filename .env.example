# SIA PO — modèle de configuration d'environnement (S1.4)
#
# Usage (dev local / pod Onyxia) :
#   cp .env.example .env      # .env est ignoré par git — la clé n'entre JAMAIS dans le repo
# puis renseigner ALBERT_API_KEY. Sans clé, l'API refuse de démarrer avec un
# message explicite. En déploiement Kubernetes, ces variables viennent d'un
# Secret (cf. infra/k8s/secret-albert.example.yaml), jamais d'un fichier.

# --- Albert API (DINUM) — inférence exclusivement via Albert (CLAUDE.md) -----
# URL de base de l'API compatible OpenAI (sans slash final).
ALBERT_BASE_URL=https://albert.api.etalab.gouv.fr/v1
# Clé d'API — SECRET : jamais commitée, jamais loguée, jamais collée dans un ticket.
ALBERT_API_KEY=
# Alias de modèles Albert (survivent aux rotations de catalogue). Valeurs par
# défaut identiques dans le code : ne surcharger qu'en cas de besoin (ex. E6).
ALBERT_MODEL_CHAT=openweight-large
ALBERT_MODEL_EMBEDDINGS=openweight-embeddings
ALBERT_MODEL_RERANK=openweight-rerank

# --- Stack locale (infra/compose.yaml) — identifiants de dev, aucune donnée réelle
POSTGRES_USER=sia
POSTGRES_PASSWORD=sia_dev
POSTGRES_DB=sia
POSTGRES_PORT=5432
API_PORT=8000
# 8080 est occupé par code-server sur les pods VSCode Onyxia -> mettre 8081.
WEB_PORT=8080
